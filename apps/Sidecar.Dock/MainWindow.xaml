<Window x:Class="ChatGPT.Sidecar.Dock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ChatGPT Sidecar Dock"
        Width="520"
        Height="900"
        MinWidth="380"
        MinHeight="520"
        Background="{StaticResource PanelBackgroundBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" Padding="14" BorderBrush="#2C3138" BorderThickness="0,0,0,1">
      <StackPanel>
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Left">
            <TextBlock Text="ChatGPT Sidecar" FontSize="18" FontWeight="SemiBold" />
            <TextBlock x:Name="DetectedContextText" Text="Waiting for Codex..." Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
            <Button Content="Reload ChatGPT" Margin="8,0,0,0" Padding="10,5" Click="ReloadChatGpt_OnClick" />
            <Button Content="Copy diagnostics" Margin="8,0,0,0" Padding="10,5" Click="CopyDiagnostics_OnClick" />
          </WrapPanel>
        </DockPanel>

        <Grid Margin="0,12,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock x:Name="DockTargetText" Text="Target: automatic detection" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="AttachHintText" Text="Drag Attach over the Codex window and release" Margin="0,2,8,0" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <Border x:Name="AttachTargetHandle"
                  Grid.Column="1"
                  Margin="8,0,0,0"
                  Padding="11,6"
                  CornerRadius="4"
                  Background="#28333D"
                  BorderBrush="#52616E"
                  BorderThickness="1"
                  Cursor="Cross"
                  ToolTip="Hold and drag this handle over the real Codex window, then release"
                  PreviewMouseLeftButtonDown="AttachTargetHandle_OnMouseLeftButtonDown"
                  PreviewMouseMove="AttachTargetHandle_OnMouseMove"
                  PreviewMouseLeftButtonUp="AttachTargetHandle_OnMouseLeftButtonUp"
                  LostMouseCapture="AttachTargetHandle_OnLostMouseCapture">
            <TextBlock Text="⠿ Attach" FontWeight="SemiBold" />
          </Border>
          <Button Grid.Column="2" Content="Auto target" Margin="8,0,0,0" Padding="10,5" Click="AutoTargetButton_OnClick" />
          <ToggleButton x:Name="FollowCodexToggle" Grid.Column="3" Content="Follow" IsChecked="True" Margin="8,0,0,0" Padding="10,5" Click="FollowCodexToggle_OnChanged" />
        </Grid>

        <Grid Margin="0,12,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Thread" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" />
          <ComboBox x:Name="ThreadBox"
                    Grid.Column="1"
                    MinWidth="220"
                    MaxDropDownHeight="420"
                    SelectionChanged="ThreadBox_OnSelectionChanged" />
          <Button Grid.Column="2" Content="Refresh" Margin="8,0,0,0" Padding="10,5" Click="RefreshThreadsButton_OnClick" />
        </Grid>

        <Grid Margin="0,10,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <ComboBox x:Name="ModeBox" Grid.Column="0" SelectedIndex="0" Margin="0,0,8,0">
            <ComboBoxItem Content="Plan" Tag="plan" />
            <ComboBoxItem Content="Debug" Tag="debug" />
            <ComboBoxItem Content="Review" Tag="review" />
            <ComboBoxItem Content="General" Tag="general" />
          </ComboBox>
          <TextBox x:Name="RequestBox"
                   Grid.Column="1"
                   MinHeight="58"
                   TextWrapping="Wrap"
                   AcceptsReturn="True"
                   VerticalScrollBarVisibility="Auto"
                   Text="Summarize the current Codex work and determine the best next implementation step." />
        </Grid>

        <DockPanel Margin="0,10,0,0">
          <Button x:Name="PrepareButton" Content="Prepare in ChatGPT" Padding="14,7" Click="PrepareButton_OnClick" />
          <Button Content="Preview context" Margin="8,0,0,0" Padding="12,7" Click="PreviewButton_OnClick" />
          <TextBlock x:Name="ContextStatsText" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
        </DockPanel>
      </StackPanel>
    </Border>

    <wv2:WebView2 x:Name="ChatGptWebView" Grid.Row="1" DefaultBackgroundColor="#101214" />

    <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}" Padding="10,7" BorderBrush="#2C3138" BorderThickness="0,1,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock x:Name="StatusText" Text="Starting Sidecar..." Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
          <TextBlock x:Name="BrowserStatusText" Text="WebView: initializing" Margin="0,2,0,0" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Populate-only alpha" Foreground="{StaticResource SecondaryTextBrush}" />
      </Grid>
    </Border>
  </Grid>
</Window>