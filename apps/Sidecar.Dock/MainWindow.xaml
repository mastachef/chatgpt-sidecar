<Window x:Class="ChatGPT.Sidecar.Dock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Sidecar"
        Icon="Assets/Sidecar.ico"
        Width="500"
        Height="900"
        MinWidth="420"
        MinHeight="600"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="MainWindow_OnStateChanged">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        ResizeBorderThickness="6"
                        GlassFrameThickness="0"
                        CornerRadius="0"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <Style x:Key="CaptionButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="46" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="FontFamily" Value="Segoe UI Symbol" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Cursor" Value="Arrow" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="CaptionButtonBorder"
                    Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CaptionButtonBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="CaptionButtonBorder" Property="Opacity" Value="0.72" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="CloseCaptionButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
          <Setter Property="Foreground" Value="White" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Border Background="{DynamicResource WindowBackgroundBrush}"
          BorderBrush="{DynamicResource BorderBrush}"
          BorderThickness="1">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
      <Grid.RowDefinitions>
        <RowDefinition Height="34" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,0,0,1"
              MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Image Width="17"
                 Height="17"
                 Margin="9,0,7,0"
                 VerticalAlignment="Center"
                 Source="Assets/Sidecar.ico"
                 Stretch="Uniform" />
          <TextBlock Grid.Column="1"
                     Text="Sidecar"
                     VerticalAlignment="Center"
                     FontFamily="{DynamicResource AppFont}"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PrimaryTextBrush}" />

          <Button Grid.Column="2"
                  Style="{StaticResource CaptionButtonStyle}"
                  Content="—"
                  ToolTip="Minimize"
                  Click="MinimizeButton_OnClick" />
          <Button x:Name="MaximizeButton"
                  Grid.Column="3"
                  Style="{StaticResource CaptionButtonStyle}"
                  Content="□"
                  ToolTip="Maximize"
                  Click="MaximizeButton_OnClick" />
          <Button Grid.Column="4"
                  Style="{StaticResource CloseCaptionButtonStyle}"
                  Content="×"
                  FontSize="17"
                  ToolTip="Close"
                  Click="CloseButton_OnClick" />
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,0,0,1"
              Padding="12,10">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="36" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Border Width="30" Height="30" CornerRadius="7" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
            <Image Source="Assets/Sidecar.ico" Stretch="UniformToFill" />
          </Border>

          <StackPanel Grid.Column="1" Margin="9,0,12,0" VerticalAlignment="Center">
            <TextBlock Text="SIDECAR" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Text="Save Codex usage. Think beside it." FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,1,0,0" />
          </StackPanel>

          <ComboBox x:Name="ThemeBox"
                    Grid.Column="2"
                    Width="122"
                    VerticalAlignment="Center"
                    SelectionChanged="ThemeBox_OnSelectionChanged"
                    ToolTip="Match Sidecar to your Codex theme" />
          <Button Grid.Column="3" Style="{StaticResource QuietButtonStyle}" Content="Reload" Margin="7,0,0,0" Click="ReloadChatGpt_OnClick" />
          <Button Grid.Column="4" Style="{StaticResource QuietButtonStyle}" Content="Diagnostics" Margin="2,0,0,0" Click="CopyDiagnostics_OnClick" />
        </Grid>
      </Border>

      <StackPanel Grid.Row="2" Margin="12,12,12,10">
        <Border Style="{StaticResource CardStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="DOCK TARGET" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
              <TextBlock x:Name="DockTargetText" Text="No target selected" FontWeight="SemiBold" Margin="0,3,8,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Border x:Name="AttachTargetHandle"
                    Grid.Column="1"
                    Padding="12,7"
                    CornerRadius="6"
                    Background="{DynamicResource AccentSoftBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    Cursor="Cross"
                    ToolTip="Hold and drag this handle over the real Codex window, then release"
                    PreviewMouseLeftButtonDown="AttachTargetHandle_OnMouseLeftButtonDown"
                    PreviewMouseMove="AttachTargetHandle_OnMouseMove"
                    PreviewMouseLeftButtonUp="AttachTargetHandle_OnMouseLeftButtonUp"
                    LostMouseCapture="AttachTargetHandle_OnLostMouseCapture">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="⠿" Foreground="{DynamicResource AccentBrush}" FontSize="14" Margin="0,-1,6,0" />
                <TextBlock Text="Attach" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
              </StackPanel>
            </Border>

            <ToggleButton x:Name="FollowCodexToggle" Grid.Column="2" Content="Follow" IsChecked="True" Margin="7,0,0,0" Click="FollowCodexToggle_OnChanged" />

            <TextBlock x:Name="AttachHintText"
                       Grid.Row="1"
                       Grid.ColumnSpan="3"
                       Text="Sidecar will not choose a window automatically. Drag Attach onto the exact Codex window you want it to follow."
                       Margin="0,9,0,0"
                       FontSize="10"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap" />
          </Grid>
        </Border>

        <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="CODEX CONTEXT" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
                <TextBlock x:Name="DetectedContextText" Text="Waiting for a saved Codex conversation..." Margin="0,3,8,0" TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <Button Grid.Column="1" Style="{StaticResource QuietButtonStyle}" Content="Refresh threads" Click="RefreshThreadsButton_OnClick" />
            </Grid>

            <ComboBox x:Name="ThreadBox"
                      Margin="0,9,0,0"
                      MaxDropDownHeight="420"
                      SelectionChanged="ThreadBox_OnSelectionChanged" />

            <Grid Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <ComboBox x:Name="ModeBox" Grid.Column="0" SelectedIndex="0" Margin="0,0,8,0">
                <ComboBoxItem Content="Plan" Tag="plan" />
                <ComboBoxItem Content="Debug" Tag="debug" />
                <ComboBoxItem Content="Review" Tag="review" />
                <ComboBoxItem Content="General" Tag="general" />
              </ComboBox>
              <TextBox x:Name="RequestBox"
                       Grid.Column="1"
                       MinHeight="66"
                       TextWrapping="Wrap"
                       AcceptsReturn="True"
                       VerticalScrollBarVisibility="Auto"
                       Text="Summarize the current Codex work and determine the best next implementation step." />
            </Grid>

            <Grid Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Button x:Name="PrepareButton" Style="{StaticResource PrimaryButtonStyle}" Content="Prepare in ChatGPT" Click="PrepareButton_OnClick" />
              <Button Grid.Column="1" Content="Preview" Margin="8,0,0,0" Click="PreviewButton_OnClick" />
              <TextBlock x:Name="ContextStatsText" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}" />
            </Grid>

            <Border Margin="0,12,0,0"
                    Padding="0,11,0,0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                  <TextBlock Text="RETURN TO CODEX" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" />
                  <TextBlock Text="After finishing in ChatGPT, generate a detailed implementation handoff and copy the finished reply back into Codex."
                             Margin="0,3,0,0"
                             FontSize="10"
                             Foreground="{DynamicResource SecondaryTextBrush}"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Button x:Name="PrepareHandoffButton"
                        Grid.Column="1"
                        Content="Prepare handoff"
                        ToolTip="Ask ChatGPT to produce a detailed prompt for continuing in Codex"
                        Click="PrepareCodexHandoffButton_OnClick" />
                <Button x:Name="CopyHandoffButton"
                        Grid.Column="2"
                        Content="Copy latest reply"
                        Margin="8,0,0,0"
                        ToolTip="Copy ChatGPT's latest response so it can be pasted into Codex"
                        Click="CopyLatestReplyButton_OnClick" />
              </Grid>
            </Border>
          </StackPanel>
        </Border>
      </StackPanel>

      <Border Grid.Row="3"
              Margin="12,0,12,10"
              CornerRadius="10"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              Background="{DynamicResource BrowserBackdropBrush}"
              ClipToBounds="True">
        <Grid>
          <wv2:WebView2 x:Name="ChatGptWebView" DefaultBackgroundColor="#020703" />
          <Border VerticalAlignment="Top" Height="1" Background="{DynamicResource AccentSoftBrush}" IsHitTestVisible="False" />
        </Grid>
      </Border>

      <Border Grid.Row="4"
              Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,1,0,0"
              Padding="12,8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock x:Name="StatusText" Text="Starting Sidecar..." FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="BrowserStatusText" Text="WebView: initializing" Margin="0,2,0,0" FontSize="9" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <Border Grid.Column="1" Background="{DynamicResource AccentSoftBrush}" CornerRadius="5" Padding="7,4" VerticalAlignment="Center">
            <TextBlock Text="POPULATE ONLY" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
          </Border>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
