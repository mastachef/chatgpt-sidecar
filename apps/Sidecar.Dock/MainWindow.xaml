<Window x:Class="ChatGPT.Sidecar.Dock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ChatGPT Sidecar Dock"
        Width="520"
        Height="900"
        MinWidth="380"
        MinHeight="520"
        Background="{StaticResource PanelBackgroundBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" Padding="14" BorderBrush="#2C3138" BorderThickness="0,0,0,1">
      <StackPanel>
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Left">
            <TextBlock Text="ChatGPT Sidecar" FontSize="18" FontWeight="SemiBold" />
            <TextBlock x:Name="DetectedContextText" Text="Waiting for Codex..." Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3,0,0" />
          </StackPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
            <ToggleButton x:Name="FollowCodexToggle" Content="Follow Codex" IsChecked="True" Margin="8,0,0,0" Padding="10,5" Checked="FollowCodexToggle_OnChanged" Unchecked="FollowCodexToggle_OnChanged" />
            <Button Content="Reload" Margin="8,0,0,0" Padding="10,5" Click="ReloadChatGpt_OnClick" />
          </StackPanel>
        </DockPanel>

        <Grid Margin="0,12,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <ComboBox x:Name="ModeBox" Grid.Column="0" SelectedIndex="0" Margin="0,0,8,0">
            <ComboBoxItem Content="Plan" Tag="plan" />
            <ComboBoxItem Content="Debug" Tag="debug" />
            <ComboBoxItem Content="Review" Tag="review" />
            <ComboBoxItem Content="General" Tag="general" />
          </ComboBox>
          <TextBox x:Name="RequestBox"
                   Grid.Column="1"
                   MinHeight="58"
                   TextWrapping="Wrap"
                   AcceptsReturn="True"
                   VerticalScrollBarVisibility="Auto"
                   Text="Summarize the current Codex work and determine the best next implementation step." />
        </Grid>

        <DockPanel Margin="0,10,0,0">
          <Button x:Name="PrepareButton" Content="Prepare in ChatGPT" Padding="14,7" Click="PrepareButton_OnClick" />
          <Button Content="Preview context" Margin="8,0,0,0" Padding="12,7" Click="PreviewButton_OnClick" />
          <TextBlock x:Name="ContextStatsText" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
        </DockPanel>
      </StackPanel>
    </Border>

    <wv2:WebView2 x:Name="ChatGptWebView" Grid.Row="1" DefaultBackgroundColor="#101214" />

    <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}" Padding="10,7" BorderBrush="#2C3138" BorderThickness="0,1,0,0">
      <DockPanel>
        <TextBlock x:Name="StatusText" Text="Starting Sidecar..." Foreground="{StaticResource SecondaryTextBrush}" />
        <TextBlock DockPanel.Dock="Right" Text="Populate-only alpha: review before sending" Foreground="{StaticResource SecondaryTextBrush}" />
      </DockPanel>
    </Border>
  </Grid>
</Window>
