{
  "name": "chatgpt-sidecar",
  "version": "0.5.0",
  "description": "Read saved Codex sessions and hand them to ChatGPT without submitting a Codex model turn.",
  "type": "module",
  "bin": {
    "codex-sidecar": "./bin/sidecar.mjs"
  },
  "scripts": {
    "test": "node --test",
    "doctor": "node ./bin/sidecar.mjs doctor",
    "install-launcher": "node ./bin/sidecar.mjs install-launcher",
    "launch": "node ./bin/sidecar.mjs launch",
    "bundle": "node ./bin/sidecar.mjs bundle"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "codex",
    "chatgpt",
    "sidecar",
    "developer-tools"
  ],
  "license": "MIT"
}
